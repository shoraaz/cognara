# ─────────────────────────────────────────────
# Cognara Learn — environment variable template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── GCP ───────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1                      # Delhi-closest region
GCP_SERVICE_ACCOUNT_KEY_PATH=               # leave blank if using ADC (recommended)

# ── Vertex AI ─────────────────────────────────
VERTEX_AI_LOCATION=asia-south1
VERTEX_EMBEDDING_MODEL=text-embedding-004   # 768-dim embeddings
VERTEX_GENERATION_MODEL=gemini-1.5-flash    # start cheap; swap to pro when needed

# ── Cloud Storage ─────────────────────────────
GCS_BUCKET_NAME=cognara-learn-dev           # raw PDFs + processed chunk JSONL
GCS_CHUNKS_PREFIX=processed/chunks/

# ── BigQuery ──────────────────────────────────
BQ_DATASET=cognara_eval                     # query logs + eval results
BQ_TABLE_QUERY_LOG=query_log
BQ_TABLE_EVAL_RESULTS=eval_results

# ── Vector store: Cloud SQL Postgres + pgvector ──
# For local dev, run the Cloud SQL Auth Proxy; it exposes the instance on
# 127.0.0.1:5432. CLOUD_SQL_INSTANCE is what the proxy connects to.
CLOUD_SQL_INSTANCE=your-project:asia-south1:cognara-pg
PGVECTOR_HOST=127.0.0.1
PGVECTOR_PORT=5432
PGVECTOR_DB=cognara
PGVECTOR_USER=cognara_app
PGVECTOR_PASSWORD=                          # local only; prod uses Secret Manager
PGVECTOR_TABLE=chunks
EMBEDDING_DIM=768

# ── Retrieval ─────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.35              # below this → "not in notes" response

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                             # json (prod) | pretty (local dev)

# ── App ───────────────────────────────────────
APP_ENV=development                         # development | production
APP_PORT=8000
