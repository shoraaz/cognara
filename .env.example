# ─────────────────────────────────────────────
# Cognara Learn — environment variable template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── GCP ───────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1                      # Delhi-closest region
GCP_SERVICE_ACCOUNT_KEY_PATH=               # leave blank if using ADC (recommended)

# ── Vertex AI ─────────────────────────────────
VERTEX_AI_LOCATION=asia-south1
VERTEX_EMBEDDING_MODEL=text-embedding-004   # 768-dim embeddings
# gemini-1.5-flash is FULLY SHUT DOWN (confirmed 2026-07 — 404 on every
# request). Use gemini-2.5-flash (stable, retires 2026-10-16 — check
# https://ai.google.dev/gemini-api/docs/deprecations before that date
# and update this). gemini-3.1-flash-lite is cheaper but still PREVIEW
# status (no SLA) as of this writing.
VERTEX_GENERATION_MODEL=gemini-2.5-flash

# ── Cloud Storage ─────────────────────────────
GCS_BUCKET_NAME=cognara-learn-dev           # raw PDFs + processed chunk JSONL
GCS_CHUNKS_PREFIX=processed/chunks/

# ── BigQuery ──────────────────────────────────
BQ_DATASET=cognara_eval                     # query logs + eval results
BQ_TABLE_QUERY_LOG=query_log
BQ_TABLE_EVAL_RESULTS=eval_results

# ── Vector store: Cloud SQL Postgres + pgvector ──
# Local dev connects via the Cloud SQL Python Connector (see
# ingestion/pipelines/init_db.py) with ip_type="PUBLIC" — the instance
# has a public IP with ZERO authorized networks (see ADR 0003 amendment),
# so only the Connector's IAM-authenticated tunnel can reach it. No
# separate Auth Proxy process is required for the Python code paths;
# PGVECTOR_HOST/PORT below are only used by the alternative standalone
# Auth Proxy connection path (e.g. for `psql` or a GUI client).
CLOUD_SQL_INSTANCE=your-project:asia-south1:cognara-pg
PGVECTOR_HOST=127.0.0.1
PGVECTOR_PORT=5432
PGVECTOR_DB=cognara
PGVECTOR_USER=cognara_app
PGVECTOR_PASSWORD=                          # local only; prod uses Secret Manager
PGVECTOR_TABLE=chunks
EMBEDDING_DIM=768

# ── Graph store: Neo4j AuraDB Free (Layer 6 GraphRAG — see ADR 0010) ──
# A deliberate exception to "reuse Cloud SQL" for everything — chosen to
# demonstrate real graph-database/Cypher experience. AuraDB Free tier:
# create at https://console.neo4j.io — genuinely free, no credit card,
# up to 200k nodes / 400k relationships. The connection URI and a
# generated password are shown ONCE at instance creation — save them then.
NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=                             # local only; prod uses Secret Manager

# ── Retrieval ─────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.35              # below this → "not in notes" response

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                             # json (prod) | pretty (local dev)

# ── App ───────────────────────────────────────
APP_ENV=development                         # development | production
APP_PORT=8000
